---
import { AnimatedCTA } from './AnimatedCTA';
---

<section class="relative my-[20vh] flex items-center justify-center">
  <div class="container-custom relative z-10">
    <!-- Main Content -->
    <div class="max-w-2xl lg:max-w-3xl xl:max-w-5xl mx-auto text-center">
      <!-- Headline -->
      <h1
        class="hero-headline mb-6 md:mb-8"
        data-animate="headline"
      >
        Stop debating. <i>Start building.</i>
      </h1>

      <!-- Sub-headline -->
      <p
        class="hero-subheadline text-base md:text-lg lg:text-xl leading-tight text-charcoal/70 mb-10 md:mb-12 max-w-3xl mx-auto"
        data-animate="subheadline"
      >
        Your design system is only 10 minutes away.
      </p>

      <!-- CTA Button -->
      <div data-animate="cta" class="flex flex-col items-center gap-4">
        <AnimatedCTA
          client:load
          id="hero-cta"
          variant="primary"
          size="lg"
        >
          Start Building – $75
        </AnimatedCTA>
      </div>
    </div>
  </div>

</section>

<style>
  /* Typography Animations */
  [data-animate='headline'] {
    opacity: 0;
    animation: fadeInUp 1.6s cubic-bezier(0.17,0.84,0.44,1) forwards;
    animation-delay: 0.4s;
  }

  [data-animate='subheadline'] {
    opacity: 0;
    animation: fadeInUp 1.6s cubic-bezier(0.17,0.84,0.44,1) forwards;
    animation-delay: 0.55s;
  }

  [data-animate='cta'] {
    opacity: 0;
    animation: fadeInUp 1.6s cubic-bezier(0.17,0.84,0.44,1) forwards;
    animation-delay: 0.7s;
  }
</style>

<script>
  // Connect Hero CTA to BrandIntake modal
  const heroCTA = document.getElementById('hero-cta');

  heroCTA?.addEventListener('click', () => {
    // Dispatch custom event to open BrandIntake modal
    window.dispatchEvent(new CustomEvent('openBrandIntake'));
  });
</script>