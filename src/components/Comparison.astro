---
// Comparison table - shadcn/ui vs Trellis
---

<section class="section-spacing">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-16 flex flex-col gap-4">
      <p class="text-xl text-charcoal/70 mx-auto">
        Why Trellis?
      </p>
      <h2 class="max-w-2xl mx-auto">Not Another UI Kit. This is your <i>whole system</i></h2>
    </div>

    <!-- Comparison Table -->
    <div class="max-w-5xl mx-auto">
      <div class="bg-white rounded-3xl shadow-lg overflow-hidden">
        <!-- Table Header -->
        <div class="grid grid-cols-3 gap-4 p-6 md:p-8 bg-charcoal text-cream border-b border-charcoal/10">
          <div class="font-sans font-semibold text-sm md:text-base">Feature</div>
          <div class="text-center font-sans font-semibold text-sm md:text-base">shadcn/ui</div>
          <div class="text-center font-sans font-semibold text-sm md:text-base">Trellis Starter</div>
        </div>

        <!-- Table Rows -->
        <div class="divide-y divide-charcoal/10">
          <!-- React Components -->
          <div class="grid grid-cols-3 gap-4 p-4 md:p-6 hover:bg-cream/50 transition-colors">
            <div class="font-medium text-sm md:text-base">React Components</div>
            <div class="flex justify-center">
              <span class="text-forest-green text-2xl">✓</span>
            </div>
            <div class="flex justify-center">
              <span class="text-forest-green text-2xl">✓</span>
            </div>
          </div>

          <!-- Design Tokens -->
          <div class="grid grid-cols-3 gap-4 p-4 md:p-6 hover:bg-cream/50 transition-colors">
            <div class="font-medium text-sm md:text-base">Design Tokens</div>
            <div class="flex justify-center">
              <span class="text-red-500 text-2xl">✗</span>
            </div>
            <div class="flex justify-center items-center gap-2">
              <span class="text-forest-green text-2xl">✓</span>
              <span class="text-xs text-charcoal/60 hidden md:inline">DTCG</span>
            </div>
          </div>

          <!-- Figma File -->
          <div class="grid grid-cols-3 gap-4 p-4 md:p-6 hover:bg-cream/50 transition-colors">
            <div class="font-medium text-sm md:text-base">Figma File</div>
            <div class="flex justify-center">
              <span class="text-red-500 text-2xl">✗</span>
            </div>
            <div class="flex justify-center items-center gap-2">
              <span class="text-forest-green text-2xl">✓</span>
              <span class="text-xs text-charcoal/60 hidden md:inline">with variables</span>
            </div>
          </div>

          <!-- Monorepo Setup -->
          <div class="grid grid-cols-3 gap-4 p-4 md:p-6 hover:bg-cream/50 transition-colors">
            <div class="font-medium text-sm md:text-base">Monorepo Setup</div>
            <div class="flex justify-center">
              <span class="text-red-500 text-2xl">✗</span>
            </div>
            <div class="flex justify-center items-center gap-2">
              <span class="text-forest-green text-2xl">✓</span>
              <span class="text-xs text-charcoal/60 hidden md:inline">Turborepo</span>
            </div>
          </div>

          <!-- Documentation -->
          <div class="grid grid-cols-3 gap-4 p-4 md:p-6 hover:bg-cream/50 transition-colors">
            <div class="font-medium text-sm md:text-base">Documentation</div>
            <div class="flex justify-center">
              <span class="text-red-500 text-2xl">✗</span>
            </div>
            <div class="flex justify-center items-center gap-2">
              <span class="text-forest-green text-2xl">✓</span>
              <span class="text-xs text-charcoal/60 hidden md:inline">Starlight site</span>
            </div>
          </div>

          <!-- Governance Templates -->
          <div class="grid grid-cols-3 gap-4 p-4 md:p-6 hover:bg-cream/50 transition-colors">
            <div class="font-medium text-sm md:text-base">Governance Templates</div>
            <div class="flex justify-center">
              <span class="text-red-500 text-2xl">✗</span>
            </div>
            <div class="flex justify-center items-center gap-2">
              <span class="text-forest-green text-2xl">✓</span>
              <span class="text-xs text-charcoal/60 hidden md:inline">Notion + GitHub</span>
            </div>
          </div>

          <!-- Setup Time - Highlighted Row -->
          <div class="grid grid-cols-3 gap-4 p-4 md:p-6 bg-forest-green/5 border-2 border-forest-green/20">
            <div class="font-semibold text-sm md:text-base">Setup Time</div>
            <div class="text-center">
              <div class="text-lg md:text-xl font-semibold text-red-500">2-6 months</div>
            </div>
            <div class="text-center">
              <div class="text-lg md:text-xl font-semibold text-forest-green">10 minutes</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Note -->
      <div class="mt-8 text-center">
        <p class="text-charcoal/60 text-sm md:text-base">
          * shadcn/ui is an excellent component library. Trellis builds on that foundation
          with tokens, Figma files, and governance.
        </p>
      </div>
    </div>
  </div>
</section>
