            ></path>
          </svg>
        </div>
        <h3 class="text-2xl mb-3">React Components</h3>
        <p class="text-charcoal/70">
          25 base UI components with TypeScript, ARIA accessibility, and Vitest
          unit tests.
        </p>
      </div>

      <!-- Figma File -->
      <div class="card" data-animate-card>
        <div class="w-16 h-16 mb-6 flex items-center justify-center rounded-2xl bg-forest-green/10">
          <svg class="w-8 h-8 text-forest-green" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M15.852 8.981h-4.588V0h4.588c2.476 0 4.49 2.014 4.49 4.49s-2.014 4.491-4.49 4.491zM12.735 7.51h3.117c1.665 0 3.019-1.355 3.019-3.019s-1.355-3.019-3.019-3.019h-3.117V7.51zm0 1.471H8.148c-2.476 0-4.49-2.014-4.49-4.49S5.672 0 8.148 0h4.588v8.981zm-4.587-7.51c-1.665 0-3.019 1.355-3.019 3.019s1.354 3.02 3.019 3.02h3.117V1.471H8.148zm4.587 15.019H8.148c-2.476 0-4.49-2.014-4.49-4.49s2.014-4.49 4.49-4.49h4.588v8.98zM8.148 8.981c-1.665 0-3.019 1.355-3.019 3.019s1.355 3.019 3.019 3.019h3.117V8.981H8.148zM8.172 24c-2.489 0-4.515-2.014-4.515-4.49s2.014-4.49 4.49-4.49h4.588v4.441c0 2.503-2.047 4.539-4.563 4.539zm-.024-7.51a3.023 3.023 0 0 0-3.019 3.019c0 1.665 1.365 3.019 3.044 3.019 1.705 0 3.093-1.376 3.093-3.068v-2.97H8.148zm7.704 0h-.098c-2.476 0-4.49-2.014-4.49-4.49s2.014-4.49 4.49-4.49h.098c2.476 0 4.49 2.014 4.49 4.49s-2.014 4.49-4.49 4.49zm-.097-7.509c-1.665 0-3.019 1.355-3.019 3.019s1.355 3.019 3.019 3.019h.098c1.665 0 3.019-1.355 3.019-3.019s-1.355-3.019-3.019-3.019h-.098z"
            ></path>
          </svg>
        </div>
        <h3 class="text-2xl mb-3">Figma File</h3>
        <p class="text-charcoal/70">
          Components with variables mapped to tokens and light/dark mode support.
        </p>
      </div>

      <!-- Monorepo Setup -->
      <div class="card" data-animate-card>
        <div class="w-16 h-16 mb-6 flex items-center justify-center rounded-2xl bg-forest-green/10">
          <svg class="w-8 h-8 text-forest-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"
            ></path>
          </svg>
        </div>
        <h3 class="text-2xl mb-3">Monorepo Setup</h3>
        <p class="text-charcoal/70">
          pnpm + Turborepo + Storybook 8 pre-configured and ready to run.
        </p>
      </div>

      <!-- Documentation Site -->
      <div class="card" data-animate-card>
        <div class="w-16 h-16 mb-6 flex items-center justify-center rounded-2xl bg-forest-green/10">
          <svg class="w-8 h-8 text-forest-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
            ></path>
          </svg>
        </div>
        <h3 class="text-2xl mb-3">Documentation Site</h3>
        <p class="text-charcoal/70">
          Starlight doc site with component index, design principles, and
          contribution guidelines.
        </p>
      </div>

      <!-- Governance Templates -->
      <div class="card" data-animate-card>
        <div class="w-16 h-16 mb-6 flex items-center justify-center rounded-2xl bg-forest-green/10">
          <svg class="w-8 h-8 text-forest-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            ></path>
          </svg>
        </div>
        <h3 class="text-2xl mb-3">Governance Templates</h3>
        <p class="text-charcoal/70">
          Markdown templates for Notion/Confluence and GitHub issue templates.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  [data-animate-card] {
    opacity: 0;
    transform: translateY(30px);
  }

  [data-animate-card].in-view {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  /* Stagger the animations */
  [data-animate-card]:nth-child(1).in-view {
    animation-delay: 0.1s;
  }
  [data-animate-card]:nth-child(2).in-view {
    animation-delay: 0.2s;
  }
  [data-animate-card]:nth-child(3).in-view {
    animation-delay: 0.3s;
  }
  [data-animate-card]:nth-child(4).in-view {
    animation-delay: 0.4s;
  }
  [data-animate-card]:nth-child(5).in-view {
    animation-delay: 0.5s;
  }
  [data-animate-card]:nth-child(6).in-view {
    animation-delay: 0.6s;
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const cards = document.querySelectorAll('[data-animate-card]');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
        }
      });
    },
    {
      threshold: 0.1,
      rootMargin: '0px 0px -100px 0px',
    }
  );

  cards.forEach((card) => observer.observe(card));
</script>
