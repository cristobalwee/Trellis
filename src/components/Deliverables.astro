---
// Deliverables - "Everything included" section
---

<section class="section-spacing bg-white">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="mb-4">Everything included</h2>
      <p class="text-xl text-charcoal/70 max-w-2xl mx-auto">
        A complete design system starter kit with everything you need to build
        production-ready products.
      </p>
    </div>

    <!-- Deliverables Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      <!-- Design Tokens -->
      <div class="card" data-animate-card>
        <div class="w-16 h-16 mb-6 flex items-center justify-center rounded-2xl bg-forest-green/10">
          <svg class="w-8 h-8 text-forest-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
            ></path>
          </svg>
        </div>
        <h3 class="text-2xl mb-3">Design Tokens</h3>
        <p class="text-charcoal/70">
          DTCG-compliant tokens for colors (light/dark), typography, spacing, and
          shadows.
        </p>
      </div>

      <!-- React Components -->
