---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import BrandIntake from '../components/BrandIntake.tsx';
import ScrollAnimationSection from '../components/ScrollAnimationSection.astro';
import Deliverables from '../components/Deliverables.astro';
import Comparison from '../components/Comparison.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
---

<BaseLayout>
  <Header />
  <main>
    <Hero />

    <!-- Brand Intake Modal (React Island) -->
    <BrandIntake client:only="react" />

    <!-- Interactive Scroll Animation -->
    <ScrollAnimationSection />

    <Deliverables />
    <Comparison />
    <Pricing />
    <FAQ />
  </main>
  <Footer />
</BaseLayout>
