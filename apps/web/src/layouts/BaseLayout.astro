---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Trellis - Build a design system in 10 minutes',
  description = 'Tokens, components, Figma, and complete documentation—customized to your brand. Skip the 6-month setup and start building today.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="lenis">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Preload fonts for better performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />

    <!-- Locomotive Scroll v5 -->
    <script>
      import LocomotiveScroll from 'locomotive-scroll';

      // Initialize Locomotive Scroll (built on Lenis)
      const scroll = new LocomotiveScroll({
        lenisOptions: {
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          orientation: 'vertical',
          gestureOrientation: 'vertical',
          smoothWheel: true,
          wheelMultiplier: 1,
          touchMultiplier: 2,
        },
      });

      // Expose scroll instance to window for debugging
      if (typeof window !== 'undefined') {
        (window as any).locomotiveScroll = scroll;
        (window as any).lenis = scroll.lenisInstance;
      }

      // Handle anchor link smooth scrolling
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const targetId = (this as HTMLAnchorElement).getAttribute('href');
          if (targetId && targetId !== '#') {
            const target = document.querySelector(targetId);
            if (target) {
              scroll.scrollTo(target as HTMLElement, {
                offset: 0,
                duration: 1.5,
              });
            }
          }
        });
      });
    </script>
  </body>
</html>
