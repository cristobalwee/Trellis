---
const steps = [
  {
    number: "01",
    title: "Generate your tokens",
    description:
      "Walk through the brand intake, preview your system, and download a complete token package: DTCG source files, CSS custom properties, Tailwind config, and Figma variables.",
  },
  {
    number: "02",
    title: "Drop them in your project",
    description:
      "Import one CSS file or extend your Tailwind config. Tokens cascade through your app instantly — every surface, color, and spacing value updates in one step.",
  },
  {
    number: "03",
    title: "Start building",
    description:
      "Your design decisions are embedded in the tokens. Build components and layouts on a foundation that's consistent by default and fully overridable when you need it.",
  },
];
---

<section id="how-it-works" class="section-spacing mb-16">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-16 md:mb-20 flex flex-col gap-4">
      <h2 class="max-w-3xl mx-auto">Brand to production in 5&nbsp;minutes</h2>
      <p class="text-base md:text-lg text-charcoal/80 max-w-2xl mx-auto">
        Your tokens are designed to drop into any stack — no build plugins, no config merging, no lock-in.
      </p>
    </div>

    <!-- Pipeline Cards -->
    <div class="pipeline-grid max-w-6xl mx-auto">

      <!-- Card 1: Generate your tokens -->
      <div class="pipeline-card flex flex-col">
        <div class="anim-container aspect-[4/3] rounded-2xl bg-gray mb-6">
          <div class="anim1" data-anim="color-swatch">
            <div class="anim1-header">
              <div class="anim1-swatch"></div>
              <div class="anim1-hex"><span class="anim1-hex-hash">#</span><span class="anim1-hex-val"></span></div>
            </div>
            <div class="anim1-ramps">
              {[0,1,2].map(r => (
                <div class="anim1-row" data-row={r}>
                  {Array.from({length: 8}, (_, c) => (
                    <div class="anim1-cell" data-col={c}></div>
                  ))}
                </div>
              ))}
            </div>
            <svg class="anim1-ptr" enable-background="new 0 0 32 32" viewBox="0 0 32 32" width="48" height="48" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><clipPath id="a"><path d="m0 0h32v32h-32z"/></clipPath><path clip-path="url(#a)" d="m11.3 20.4c-.3-.4-.6-1.1-1.2-2-.3-.5-1.2-1.5-1.5-1.9-.2-.4-.2-.6-.1-1 .1-.6.7-1.1 1.4-1.1.5 0 1 .4 1.4.7.2.2.5.6.7.8s.2.3.4.5c.2.3.3.5.2.1-.1-.5-.2-1.3-.4-2.1-.1-.6-.2-.7-.3-1.1-.1-.5-.2-.8-.3-1.3-.1-.3-.2-1.1-.3-1.5-.1-.5-.1-1.4.3-1.8.3-.3.9-.4 1.3-.2.5.3.8 1 .9 1.3.2.5.4 1.2.5 2 .2 1 .5 2.5.5 2.8 0-.4-.1-1.1 0-1.5.1-.3.3-.7.7-.8.3-.1.6-.1.9-.1.3.1.6.3.8.5.4.6.4 1.9.4 1.8.1-.4.1-1.2.3-1.6.1-.2.5-.4.7-.5.3-.1.7-.1 1 0 .2 0 .6.3.7.5.2.3.3 1.3.4 1.7 0 .1.1-.4.3-.7.4-.6 1.8-.8 1.9.6v1.1 1.2c0 .4-.1 1.3-.2 1.7-.1.3-.4 1-.7 1.4 0 0-1.1 1.2-1.2 1.8s-.1.6-.1 1 .1.9.1.9-.8.1-1.2 0-.9-.8-1-1.1c-.2-.3-.5-.3-.7 0-.2.4-.7 1.1-1.1 1.1-.7.1-2.1 0-3.1 0 0 0 .2-1-.2-1.4-.3-.3-.8-.8-1.1-1.1z" fill="#fff"/><g fill="none" stroke="#000" stroke-linecap="round" stroke-width=".75"><path clip-path="url(#a)" d="m11.3 20.4c-.3-.4-.6-1.1-1.2-2-.3-.5-1.2-1.5-1.5-1.9-.2-.4-.2-.6-.1-1 .1-.6.7-1.1 1.4-1.1.5 0 1 .4 1.4.7.2.2.5.6.7.8s.2.3.4.5c.2.3.3.5.2.1-.1-.5-.2-1.3-.4-2.1-.1-.6-.2-.7-.3-1.1-.1-.5-.2-.8-.3-1.3-.1-.3-.2-1.1-.3-1.5-.1-.5-.1-1.4.3-1.8.3-.3.9-.4 1.3-.2.5.3.8 1 .9 1.3.2.5.4 1.2.5 2 .2 1 .5 2.5.5 2.8 0-.4-.1-1.1 0-1.5.1-.3.3-.7.7-.8.3-.1.6-.1.9-.1.3.1.6.3.8.5.4.6.4 1.9.4 1.8.1-.4.1-1.2.3-1.6.1-.2.5-.4.7-.5.3-.1.7-.1 1 0 .2 0 .6.3.7.5.2.3.3 1.3.4 1.7 0 .1.1-.4.3-.7.4-.6 1.8-.8 1.9.6v1.1 1.2c0 .4-.1 1.3-.2 1.7-.1.3-.4 1-.7 1.4 0 0-1.1 1.2-1.2 1.8s-.1.6-.1 1 .1.9.1.9-.8.1-1.2 0-.9-.8-1-1.1c-.2-.3-.5-.3-.7 0-.2.4-.7 1.1-1.1 1.1-.7.1-2.1 0-3.1 0 0 0 .2-1-.2-1.4-.3-.3-.8-.8-1.1-1.1z" stroke-linejoin="round"/><path clip-path="url(#a)" d="m19.6 20.7v-3.4"/><path clip-path="url(#a)" d="m17.6 20.7-.1-3.4"/><path clip-path="url(#a)" d="m15.6 17.3v3.4"/></g></svg>
          </div>
        </div>
        <span class="text-sm font-mono text-charcoal/40 mb-2 block">01</span>
        <h5 class="mb-2">Configure your system</h5>
        <p class="text-sm md:text-base text-charcoal/80">{steps[0].description}</p>
      </div>

      <!-- Card 2: Drop them in your project -->
      <div class="pipeline-card flex flex-col">
        <div class="anim-container aspect-[4/3] rounded-2xl bg-gray mb-6">
          <div class="anim2">
            <div class="anim2-bar anim2-bar-1"></div>
            <div class="anim2-bar anim2-bar-2"></div>
            <div class="anim2-token"></div>
            <div class="anim2-bar anim2-bar-3"></div>
            <div class="anim2-bar anim2-bar-4"></div>
            <div class="anim2-bar anim2-bar-5"></div>
          </div>
        </div>
        <span class="text-sm font-mono text-charcoal/40 mb-2 block">02</span>
        <h5 class="mb-2">Generate your config</h5>
        <p class="text-sm md:text-base text-charcoal/80">{steps[1].description}</p>
      </div>

      <!-- Card 3: Start building -->
      <div class="pipeline-card flex flex-col">
        <div class="anim-container aspect-[4/3] rounded-2xl bg-gray mb-6">
          <div class="anim3">
            <!-- Browser frame -->
            <div class="anim3-frame">
              <div class="anim3-nav"></div>
              <div class="anim3-body">
                <div class="anim3-sidebar"></div>
                <div class="anim3-main">
                  <div class="anim3-block anim3-block-1"></div>
                  <div class="anim3-block anim3-block-2"></div>
                  <div class="anim3-block anim3-block-3"></div>
                  <div class="anim3-btn"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <span class="text-sm font-mono text-charcoal/40 mb-2 block">03</span>
        <h5 class="mb-2">Start building</h5>
        <p class="text-sm md:text-base text-charcoal/80">{steps[2].description}</p>
      </div>

    </div>
  </div>
</section>

<style>
    /* ---- Layout ---- */
  .pipeline-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .pipeline-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
  }

  /* ---- Shared animation container ---- */
  .anim-container {
    position: relative;
    overflow: hidden;
  }

  /* ---- Easing tokens ---- */
  :root {
    --ease-anim: cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ============================================
     ANIMATION 1 — Color swatch + ramp cascade
     Total loop: ~12.5s (JS-driven)
     ============================================ */
  .anim1 {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
    padding: 10% 12%;
    gap: 8%;
  }

  /* Swatch + hex row */
  .anim1-header {
    display: flex;
    align-items: center;
    gap: 10%;
  }

  .anim1-swatch {
    width: 24%;
    aspect-ratio: 1;
    border-radius: 18%;
    border: 3px solid white;
    box-shadow: 0 3px 14px oklch(24.3% 0 0 / 0.10), 0 1px 3px oklch(24.3% 0 0 / 0.06);
    transition: background-color 0.35s var(--ease-anim), transform 0.15s var(--ease-anim);
    flex-shrink: 0;
    will-change: background-color, transform;
  }

  .anim1-swatch.is-pressed {
    transform: scale(0.88);
    box-shadow: 0 1px 6px oklch(24.3% 0 0 / 0.08);
  }

  /* Hex input display */
  .anim1-hex {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: oklch(24.3% 0 0 / 0.65);
    background: white;
    border: 1px solid oklch(24.3% 0 0 / 0.10);
    border-radius: 6px;
    padding: 5px 8px;
    line-height: 1;
    white-space: nowrap;
  }

  .anim1-hex-hash {
    color: oklch(24.3% 0 0 / 0.30);
  }

  .anim1-hex-val {
    transition: color 0.01s;
  }

  /* Ramp rows */
  .anim1-ramps {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .anim1-row {
    display: flex;
    overflow: hidden;
    border-radius: 4px;
  }

  .anim1-cell {
    flex: 1;
    height: 18px;
    transition: background-color 0.3s var(--ease-anim);
    will-change: background-color, transform;
  }

  .anim1-cell.is-popping {
    animation: a1-pop 0.25s cubic-bezier(0.34, 1.4, 0.64, 1);
  }

  @keyframes a1-pop {
    0%   { transform: scaleY(1); }
    45%  { transform: scaleY(1.10); }
    100% { transform: scaleY(1); }
  }

  /* Hand pointer cursor */
  .anim1-ptr {
    position: absolute;
    top: 28%;
    left: 26%;
    opacity: 0;
    transform: translate(100px, 70px);
    transition: opacity 0.65s ease, transform 0.65s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    z-index: 10;
    filter: drop-shadow(0 1px 3px oklch(24.3% 0 0 / 0.22));
  }

  .anim1-ptr.is-visible {
    opacity: 1;
    transform: translate(0, 0);
  }

  .anim1-ptr.is-clicking {
    transform: translate(0, 3px);
    transition-duration: 0.1s;
  }


  /* ============================================
     ANIMATION 2 — Token insertion + color cascade
     Total loop: ~7s
     ============================================ */
  .anim2 {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 12% 14%;
    gap: 8%;
  }

  .anim2-bar {
    width: 80%;
    height: 8%;
    border-radius: 6px;
    background: oklch(24.3% 0 0 / 0.06);
    transition: none;
    animation: a2-bar-reset 7s var(--ease-anim) infinite;
  }

  .anim2-bar-1 { animation-name: a2-bar-outer; }
  .anim2-bar-2 { animation-name: a2-bar-mid; }
  .anim2-bar-3 { animation-name: a2-bar-center; }
  .anim2-bar-4 { animation-name: a2-bar-mid; }
  .anim2-bar-5 { animation-name: a2-bar-outer; }

  .anim2-token {
    width: 40%;
    height: 8%;
    border-radius: 6px;
    background: oklch(51.88% 0.109 151.87);
    transform: translateX(-250%);
    opacity: 0;
    animation: a2-token 7s var(--ease-anim) infinite;
  }

  /* 7s loop:
     0.0s-0.8s  token slides in
     0.8s-1.0s  bar 3 colors
     1.0s-1.2s  bars 2,4 color
     1.2s-1.4s  bars 1,5 color
     1.4s-4.4s  hold colored
     4.4s-5.0s  bars fade back (reverse stagger)
     5.0s-5.6s  token slides out
     5.6s-7.0s  pause */

  @keyframes a2-token {
    0%       { transform: translateX(-250%); opacity: 0; }
    4%       { opacity: 1; transform: translateX(-250%); }
    12%      { transform: translateX(0); opacity: 1; }
    63%      { transform: translateX(0); opacity: 1; }
    72%      { transform: translateX(0); opacity: 1; }
    80%      { transform: translateX(-250%); opacity: 1; }
    82%      { opacity: 0; }
    100%     { transform: translateX(-250%); opacity: 0; }
  }

  @keyframes a2-bar-center {
    0%, 11%  { background: oklch(24.3% 0 0 / 0.06); }
    17%      { background: oklch(51.88% 0.109 151.87 / 0.25); }
    63%      { background: oklch(51.88% 0.109 151.87 / 0.25); }
    72%      { background: oklch(24.3% 0 0 / 0.06); }
    100%     { background: oklch(24.3% 0 0 / 0.06); }
  }

  @keyframes a2-bar-mid {
    0%, 14%  { background: oklch(24.3% 0 0 / 0.06); }
    20%      { background: oklch(63% 0.14 130 / 0.2); }
    63%      { background: oklch(63% 0.14 130 / 0.2); }
    70%      { background: oklch(24.3% 0 0 / 0.06); }
    100%     { background: oklch(24.3% 0 0 / 0.06); }
  }

  @keyframes a2-bar-outer {
    0%, 17%  { background: oklch(24.3% 0 0 / 0.06); }
    23%      { background: oklch(78.10% 0.101 154.59 / 0.2); }
    63%      { background: oklch(78.10% 0.101 154.59 / 0.2); }
    68%      { background: oklch(24.3% 0 0 / 0.06); }
    100%     { background: oklch(24.3% 0 0 / 0.06); }
  }


  /* ============================================
     ANIMATION 3 — UI assembly
     Total loop: ~7s
     ============================================ */
  .anim3 {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10%;
  }

  .anim3-frame {
    width: 100%;
    height: 100%;
    border: 1px solid oklch(24.3% 0 0 / 0.1);
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: white;
  }

  .anim3-nav {
    height: 10%;
    background: oklch(51.88% 0.109 151.87 / 0.12);
    opacity: 0;
    transform: scale(0.97);
    animation: a3-el 7s var(--ease-anim) infinite;
    animation-delay: 0s;
  }

  .anim3-body {
    flex: 1;
    display: flex;
    min-height: 0;
  }

  .anim3-sidebar {
    width: 20%;
    background: oklch(97.02% 0 0);
    border-right: 1px solid oklch(24.3% 0 0 / 0.06);
    opacity: 0;
    transform: scale(0.97);
    animation: a3-el 7s var(--ease-anim) infinite;
    animation-delay: 0.12s;
  }

  .anim3-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 8%;
    gap: 6%;
  }

  .anim3-block {
    border-radius: 6px;
    opacity: 0;
    transform: scale(0.97);
    animation: a3-el 7s var(--ease-anim) infinite;
  }

  .anim3-block-1 {
    height: 30%;
    background: oklch(97.02% 0 0);
    animation-delay: 0.24s;
  }

  .anim3-block-2 {
    height: 20%;
    background: oklch(98.5% 0.006 85.7);
    border: 1px solid oklch(24.3% 0 0 / 0.05);
    animation-delay: 0.36s;
  }

  .anim3-block-3 {
    height: 22%;
    background: oklch(97.02% 0 0);
    animation-delay: 0.48s;
  }

  .anim3-btn {
    align-self: flex-end;
    width: 30%;
    height: 14%;
    border-radius: 99px;
    background: oklch(51.88% 0.109 151.87);
    opacity: 0;
    transform: scale(0.97);
    animation: a3-el 7s var(--ease-anim) infinite;
    animation-delay: 0.6s;
  }

  /* 7s loop:
     0.0s-0.8s  elements stagger in
     0.8s-4.3s  hold assembled
     4.3s-4.8s  fade out all
     4.8s-7.0s  pause */
  @keyframes a3-el {
    0%       { opacity: 0; transform: scale(0.97); }
    4%       { opacity: 0; transform: scale(0.97); }
    8%       { opacity: 1; transform: scale(1); }
    61%      { opacity: 1; transform: scale(1); }
    69%      { opacity: 0; transform: scale(1); }
    100%     { opacity: 0; transform: scale(0.97); }
  }


  /* ============================================
     Reduced motion — show final state, no animation
     ============================================ */
  @media (prefers-reduced-motion: reduce) {
    .anim1-swatch,
    .anim1-cell,
    .anim1-hex-val,
    .anim1-ptr,
    .anim2-bar,
    .anim2-token,
    .anim3-nav,
    .anim3-sidebar,
    .anim3-block,
    .anim3-btn {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }

    .anim1-ptr { display: none; }

    .anim2-bar-1, .anim2-bar-5 { background: oklch(78.10% 0.101 154.59 / 0.2) !important; }
    .anim2-bar-2, .anim2-bar-4 { background: oklch(63% 0.14 130 / 0.2) !important; }
    .anim2-bar-3 { background: oklch(51.88% 0.109 151.87 / 0.25) !important; }
  }
</style>

<script>
  (function initColorSwatchAnim() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const container = document.querySelector('[data-anim="color-swatch"]');
    if (!container) return;

    const swatch = container.querySelector('.anim1-swatch') as HTMLElement;
    const hexVal = container.querySelector('.anim1-hex-val') as HTMLElement;
    const cursor = container.querySelector('.anim1-ptr') as HTMLElement;
    const rows = Array.from(container.querySelectorAll('.anim1-row'));

    // 4 color palettes with hex approximations for the display
    const PALETTES = [
      { hue: 152, chroma: 0.11, swatchL: 0.55, hex: '2B8B6A', rows: [{ h: 152, c: 0.11 }, { h: 185, c: 0.09 }, { h: 120, c: 0.085 }] },
      { hue: 255, chroma: 0.15, swatchL: 0.52, hex: '2A5FC2', rows: [{ h: 255, c: 0.15 }, { h: 290, c: 0.11 }, { h: 225, c: 0.10 }] },
      { hue: 25,  chroma: 0.18, swatchL: 0.63, hex: 'CC5C3A', rows: [{ h: 25,  c: 0.18 }, { h: 55,  c: 0.14 }, { h: 355, c: 0.13 }] },
      { hue: 305, chroma: 0.14, swatchL: 0.54, hex: '9A3FA7', rows: [{ h: 305, c: 0.14 }, { h: 340, c: 0.11 }, { h: 275, c: 0.11 }] },
    ];

    // 8 lightness steps (light → dark) with chroma multipliers (bell curve)
    const L_STEPS = [0.95, 0.87, 0.78, 0.68, 0.57, 0.48, 0.40, 0.34];
    const C_MULT  = [0.28, 0.52, 0.78, 1.00, 0.95, 0.80, 0.62, 0.42];

    function cellColor(ci: number, c: number, h: number): string {
      return `oklch(${L_STEPS[ci]} ${(c * C_MULT[ci]).toFixed(4)} ${h})`;
    }

    function applyPalette(pi: number, stagger: boolean) {
      const p = PALETTES[pi];
      swatch.style.backgroundColor = `oklch(${p.swatchL} ${p.chroma} ${p.hue})`;
      hexVal.textContent = p.hex;

      rows.forEach((row, ri) => {
        const rc = p.rows[ri];
        const cells = row.querySelectorAll('.anim1-cell') as NodeListOf<HTMLElement>;
        cells.forEach((cell, ci) => {
          const delay = stagger ? ci * 35 : 0;
          schedule(() => {
            cell.style.backgroundColor = cellColor(ci, rc.c, rc.h);
            if (stagger) {
              cell.classList.remove('is-popping');
              void cell.offsetWidth;
              cell.classList.add('is-popping');
            }
          }, delay);
        });
      });
    }

    function doClick(pi: number) {
      swatch.classList.add('is-pressed');
      cursor.classList.add('is-clicking');
      schedule(() => {
        swatch.classList.remove('is-pressed');
        cursor.classList.remove('is-clicking');
        applyPalette(pi, true);
      }, 150);
    }

    let timeouts: ReturnType<typeof setTimeout>[] = [];

    function schedule(fn: () => void, ms: number) {
      timeouts.push(setTimeout(fn, ms));
    }

    function clearAll() {
      timeouts.forEach(clearTimeout);
      timeouts = [];
    }

    function runCycle() {
      clearAll();
      applyPalette(0, false);
      cursor.classList.remove('is-visible');
      cursor.classList.remove('is-clicking');

      schedule(() => cursor.classList.add('is-visible'), 500);   // cursor enters
      schedule(() => doClick(1), 2000);                          // click → blue
      schedule(() => doClick(2), 4200);                          // click → coral
      schedule(() => doClick(3), 6400);                          // click → purple
      schedule(() => doClick(0), 8600);                          // click → back to teal
      schedule(() => cursor.classList.remove('is-visible'), 10300); // cursor exits
      schedule(runCycle, 12500);                                 // loop
    }

    runCycle();
  })();
</script>
