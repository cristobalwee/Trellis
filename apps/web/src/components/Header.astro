---
import { AnimatedCTA } from './AnimatedCTA';
import { siteImages } from '../lib/siteImages';
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent"
  data-scrolled="false"
>
  <div class="container-custom">
    <nav
      class="flex items-center justify-between py-6 md:py-8 transition-all duration-300"
      aria-label="Main navigation"
    >
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" data-header-anim="0">
        <img src={siteImages.logo} alt="Trellis Logo" class="w-full h-full pr-[148px] hidden md:block" />
        <img src={siteImages.logoIcon} alt="Trellis Logo" class="w-[30px] h-full md:hidden" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <a
          href="#how-it-works"
          class="text-charcoal hover:text-forest-green font-medium transition-colors"
          data-header-anim="1"
        >
          How it works
        </a>
        <a
          href="#what-you-get"
          class="text-charcoal hover:text-forest-green font-medium transition-colors"
          data-header-anim="2"
        >
          What you get
        </a>
      </div>

      <!-- CTA Button — navigates to /generate -->
      <div class="flex items-center gap-1 md:gap-4" data-header-anim="4">
        <a
          href="https://github.com/cristobalwee/Trellis"
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 flex items-center gap-2 hover:text-forest-green transition-colors duration-200"
          aria-label="View Trellis on GitHub"
        >
          <svg
            aria-hidden="true"
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.09.68-.22.68-.49 0-.24-.01-1.04-.01-1.88-2.78.62-3.37-1.22-3.37-1.22-.45-1.19-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.32 9.32 0 0 1 12 6.98c.85 0 1.7.12 2.5.35 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.07.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49A10.06 10.06 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"
            />
          </svg>
          <span class="hidden sm:inline">Docs</span>
        </a>
        <AnimatedCTA
          client:load
          id="header-cta"
          href="/generate"
          variant="secondary"
          size="sm"
        >
          Start for free
        </AnimatedCTA>
      </div>
    </nav>
  </div>
</header>

<!-- Spacer to prevent content from being hidden under fixed header -->
<div class="h-20 md:h-24"></div>

<style>
  @reference "../styles/global.css";

  #header[data-scrolled='true'] {
    @apply bg-white/90 backdrop-blur-md shadow-sm shadow-black/5;
  }

  #header[data-scrolled='true'] nav {
    @apply py-3 md:py-4;
  }

  [data-header-anim] {
    opacity: 0;
    animation: headerSlideIn 0.8s cubic-bezier(0.17, 0.84, 0.44, 1) forwards;
    animation-delay: calc(1.9s + var(--header-anim-index) * 0.02s);
  }

  [data-header-anim="0"] { --header-anim-index: 0; }
  [data-header-anim="1"] { --header-anim-index: 1; }
  [data-header-anim="2"] { --header-anim-index: 2; }
  [data-header-anim="3"] { --header-anim-index: 3; }
  [data-header-anim="4"] { --header-anim-index: 4; }

  @keyframes headerSlideIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  function initHeaderScroll() {
    const header = document.getElementById('header');
    if (!header) return;

    let scrolled = false;

    const handler = () => {
      const shouldBeScrolled = window.scrollY > 50;
      if (shouldBeScrolled !== scrolled) {
        scrolled = shouldBeScrolled;
        header.setAttribute('data-scrolled', String(scrolled));
      }
    };

    // Clean up previous listener if re-initializing
    if ((window as any).__headerScrollHandler) {
      window.removeEventListener('scroll', (window as any).__headerScrollHandler);
    }
    (window as any).__headerScrollHandler = handler;

    window.addEventListener('scroll', handler, { passive: true });

    // Immediately sync state (page may be at top after navigation)
    scrolled = window.scrollY > 50;
    header.setAttribute('data-scrolled', String(scrolled));
  }

  initHeaderScroll();
  document.addEventListener('astro:after-swap', initHeaderScroll);
</script>
