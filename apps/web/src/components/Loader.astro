---
/**
 * Reusable loader component used on initial page load and Mode A route transitions.
 *
 * Modes (via `data-loader-mode`):
 *   "initial"    → first page load: plays CSS keyframe, then switches to "transition" mode
 *   "transition" → controlled programmatically by view-transitions.ts
 *
 * Uses `transition:persist` so the same DOM element survives across view-transition swaps.
 */
---

<div
  id="trellis-loader"
  class="fixed inset-0 z-100 flex items-center justify-center bg-white"
  data-loader-mode="initial"
  aria-hidden="true"
>
  <svg class="loader-logo" width="56" height="56" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M18.5409 3.33325C25.7074 3.33334 27.2909 11.2499 27.2909 15.2083V26.4583H20.2118V15.2083C20.2118 12.0127 19.1799 6.23832 15.0116 4.1311C15.9938 3.6279 17.1595 3.33325 18.5409 3.33325ZM11.4618 3.33325C12.8429 3.33325 14.0166 3.62809 15.0116 4.1311C10.898 6.23857 10.0057 12.0129 9.99889 15.2083C9.9904 19.1662 9.99889 26.4567 9.99889 26.4583H2.92076C2.92076 26.4562 2.91228 19.166 2.92076 15.2083C2.92925 11.25 4.29546 3.33354 11.4618 3.33325Z" fill="#5BA26B"/>
  </svg>
</div>

<style>
  @reference "../styles/global.css";

  /* ---- Initial page-load animation (unchanged from original) ---- */

  #trellis-loader[data-loader-mode="initial"] {
    animation: loaderOverlay 2.1s ease forwards 0.2s;
  }

  #trellis-loader[data-loader-mode="initial"] .loader-logo {
    opacity: 0;
    animation: loaderLogoIn 1.8s ease forwards 0.3s;
  }

  @keyframes loaderLogoIn {
    0%   { opacity: 0; transform: translateY(16px); }
    8%   { opacity: 0; transform: translateY(16px); }
    26%  { opacity: 1; transform: translateY(0); }
    88%  { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-16px); }
  }

  @keyframes loaderOverlay {
    0%, 90% { opacity: 1; }
    100%    { opacity: 0; }
  }

  /* ---- Transition mode: hidden by default, shown via .loader-visible ---- */

  #trellis-loader[data-loader-mode="transition"] {
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
    transition: opacity 0.35s ease;
  }

  #trellis-loader[data-loader-mode="transition"] .loader-logo {
    opacity: 0;
  }

  #trellis-loader[data-loader-mode="transition"].loader-visible {
    opacity: 1;
    pointer-events: auto;
  }

  #trellis-loader[data-loader-mode="transition"].loader-visible .loader-logo {
    animation: loaderLogoTransition 1.1s ease forwards 0.12s;
  }

  @keyframes loaderLogoTransition {
    0%   { opacity: 0; transform: translateY(12px); }
    18%  { opacity: 1; transform: translateY(0); }
    82%  { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-12px); }
  }

  /* ---- Reduced motion ---- */

  @media (prefers-reduced-motion: reduce) {
    #trellis-loader,
    #trellis-loader .loader-logo {
      animation: none !important;
      transition: none !important;
    }

    #trellis-loader[data-loader-mode="initial"] {
      opacity: 0;
    }
  }
</style>

<script>
  function initLoader(isSwap = false) {
    const loader = document.getElementById('trellis-loader');
    if (!loader) return;

    if (isSwap) {
      // View transition swap — skip loader animation, hide immediately
      loader.dataset.loaderMode = 'transition';
      loader.style.opacity = '0';
      loader.style.pointerEvents = 'none';
      const logo = loader.querySelector('.loader-logo') as HTMLElement | null;
      if (logo) {
        logo.getAnimations().forEach(a => a.cancel());
        logo.style.opacity = '0';
      }
      return;
    }

    if (loader.dataset.loaderMode === 'initial') {
      const handler = (e: AnimationEvent) => {
        if (e.target !== loader) return;
        loader.removeEventListener('animationend', handler);
        loader.dataset.loaderMode = 'transition';
        loader.style.opacity = '0';
        loader.style.pointerEvents = 'none';
        const logo = loader.querySelector('.loader-logo') as HTMLElement | null;
        if (logo) {
          logo.getAnimations().forEach(a => a.cancel());
          logo.style.opacity = '0';
        }
      };
      loader.addEventListener('animationend', handler);
    }
  }

  initLoader();
  document.addEventListener('astro:after-swap', () => initLoader(true));
</script>
