---
// What you get grid
import {
  Blocks,
  Figma,
  Braces,
  GitBranch,
  BookOpenText,
  Palette,
  ShieldCheck,
  Clock3
} from "lucide-react";
---

<section class="section-spacing">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-16 flex flex-col gap-4">
      <p class="text-base md:text-lg text-charcoal/80 mx-auto">
        Why Trellis?
      </p>
      <h2 class="max-w-2xl mx-auto">Not Another UI Kit. This is your <i>whole system</i></h2>
    </div>

    <!-- What You Get Grid -->
    <div class="max-w-4xl mx-auto">
      <div class="border border-charcoal/10 bg-white">
        <div class="grid grid-cols-1 md:grid-cols-2">
          <div class="flex gap-4 p-6 md:p-8 border-b border-charcoal/10 md:border-r">
            <div class="mt-1 text-forest-green" aria-hidden="true">
              <Blocks className="h-5 w-5" strokeWidth={1.5}/>
            </div>
            <div>
              <h5 class="mb-1">React components</h5>
              <p class="text-sm md:text-base text-charcoal/80">26 fully accessible and battle tested components, built on top of Base UI.</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 md:p-8 border-b border-charcoal/10">
            <div class="mt-1 text-forest-green" aria-hidden="true">
              <Figma className="h-5 w-5" strokeWidth={1.5}/>
            </div>
            <div>
              <h5 class="mb-1">Figma design library</h5>
              <p class="text-sm md:text-base text-charcoal/80">Component variants ready for design exploration and handoff.</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 md:p-8 border-b border-charcoal/10 md:border-r">
            <div class="mt-1 text-forest-green" aria-hidden="true">
              <Braces className="h-5 w-5" strokeWidth={1.5}/>
            </div>
            <div>
              <h5 class="mb-1">DTCG-compliant token system</h5>
              <p class="text-sm md:text-base text-charcoal/80">Token architecture built to scale, with support for light and dark mode.</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 md:p-8 border-b border-charcoal/10">
            <div class="mt-1 text-forest-green" aria-hidden="true">
              <GitBranch className="h-5 w-5" strokeWidth={1.5} />
            </div>
            <div>
              <h5 class="mb-1">Complete monorepo setup</h5>
              <p class="text-sm md:text-base text-charcoal/80">Production-ready pnpm + Turborepo architecture out of the box.</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 md:p-8 border-b border-charcoal/10 md:border-r">
            <div class="mt-1 text-forest-green" aria-hidden="true">
              <BookOpenText className="h-5 w-5" strokeWidth={1.5}/>
            </div>
            <div>
              <h5 class="mb-1">Storybook site</h5>
              <p class="text-sm md:text-base text-charcoal/80">Deployable docsite and component examples for implementation speed.</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 md:p-8 border-b border-charcoal/10">
            <div class="mt-1 text-forest-green" aria-hidden="true">
              <Palette className="h-5 w-5" strokeWidth={1.5}/>
            </div>
            <div>
              <h5 class="mb-1">Color and typography system</h5>
              <p class="text-sm md:text-base text-charcoal/80">10 WCAG-friendly color ramps and a typography scale compatible with Google Fonts.</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 md:p-8 md:border-r border-charcoal/10">
            <div class="mt-1 text-forest-green" aria-hidden="true">
              <ShieldCheck className="h-5 w-5" strokeWidth={1.5}/>
            </div>
            <div>
              <h5 class="mb-1">Governance documentation</h5>
              <p class="text-sm md:text-base text-charcoal/80">Clear rules, naming, and contribution guidance to keep teams aligned.</p>
            </div>
          </div>

          <div class="p-6 md:p-8 bg-gray/80">
            <div class="flex gap-4">
              <div class="mt-1 text-forest-green" aria-hidden="true">
                <Clock3 className="h-5 w-5" strokeWidth={1.5}/>
              </div>
              <div>
                <h5 class="mb-2">60-100+ hours saved</h5>
                <p class="text-sm md:text-base text-charcoal/80">Countless hours saved designing, building, and documenting your system.</p>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Note -->
      <div class="mt-8 text-center">
        <p class="text-charcoal/80 text-sm md:text-base">
          Trellis gives you an enterprise-level design system tailored to your brand in less than <span class="px-2 py-2 rounded-lg bg-forest-green-50 font-bold text-charcoal">10 minutes</span>.
        </p>
      </div>
    </div>
  </div>
</section>
