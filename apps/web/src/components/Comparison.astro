---
// Comparison table - shadcn/ui vs Trellis
---

<section class="section-spacing">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-16 flex flex-col gap-4">
      <p class="text-base md:text-lg text-charcoal/80 mx-auto">
        Why Trellis?
      </p>
      <h2 class="max-w-2xl mx-auto">Not Another UI Kit. This is your <i>whole system</i></h2>
    </div>

    <!-- Comparison Table -->
    <div class="max-w-4xl mx-auto">
      <div>
        <!-- Table Header -->
        <div class="grid grid-cols-3 gap-2 md:gap-12 border-b border-charcoal/10">
          <div class="text-center font-sans text-sm md:text-base p-3 md:p-6"></div>
          <div class="text-center font-sans text-sm md:text-base p-3 md:p-6"><h5>Built from scratch</h5></div>
          <div class="text-center font-sans text-sm md:text-base p-3 md:p-6"><h5>Generated by Trellis</h5></div>
        </div>

        <!-- Table Rows -->
        <div class="divide-y divide-charcoal/10">
          <div class="grid grid-cols-3 gap-2 md:gap-12">
            <div class="text-right font-medium text-sm md:text-base p-3 md:p-6"><h5>Token system</h5></div>
            <div class="text-center flex items-center justify-center font-medium text-sm md:text-base p-3 md:p-6">15-20 hrs</div>
            <div class="text-center flex items-center justify-center bg-gray font-medium text-sm md:text-base p-3 md:p-6">30 sec</div>
          </div>
          <div class="grid grid-cols-3 gap-2 md:gap-12">
            <div class="text-right font-medium text-sm md:text-base p-3 md:p-6"><h5>React components</h5></div>
            <div class="text-center flex items-center justify-center font-medium text-sm md:text-base p-3 md:p-6">10-20 dev hrs</div>
            <div class="text-center flex items-center justify-center bg-gray font-medium text-sm md:text-base p-3 md:p-6">3 min</div>
          </div>
          <div class="grid grid-cols-3 gap-2 md:gap-12">
            <div class="text-right font-medium text-sm md:text-base p-3 md:p-6"><h5>Figma library</h5></div>
            <div class="text-center flex items-center justify-center font-medium text-sm md:text-base p-3 md:p-6">30-50 design hrs</div>
            <div class="text-center flex items-center justify-center bg-gray font-medium text-sm md:text-base p-3 md:p-6">3 min</div>
          </div>
          <div class="grid grid-cols-3 gap-2 md:gap-12">
            <div class="text-right font-medium text-sm md:text-base p-3 md:p-6"><h5>Monorepo setup</h5></div>
            <div class="text-center flex items-center justify-center font-medium text-sm md:text-base p-3 md:p-6">1-2 hrs</div>
            <div class="text-center flex items-center justify-center bg-gray font-medium text-sm md:text-base p-3 md:p-6">30 sec</div>
          </div>
          <div class="grid grid-cols-3 gap-2 md:gap-12">
            <div class="text-right font-medium text-sm md:text-base p-3 md:p-6"><h5>Governance docs</h5></div>
            <div class="text-center flex items-center justify-center font-medium text-sm md:text-base p-3 md:p-6">10+ hrs</div>
            <div class="text-center flex items-center justify-center bg-gray font-medium text-sm md:text-base p-3 md:p-6">1 min</div>
          </div>
          <div class="grid grid-cols-3 gap-2 md:gap-12">
            <div class="text-right text-sm md:text-base p-3 md:p-6"><h5>Total time investment</h5></div>
            <div class="text-center flex items-center justify-center text-sm font-bold md:text-base p-3 md:p-6"><span class="md:px-4 md:py-2 md:rounded-lg md:bg-red-50">50-100+ hours</span></div>
            <div class="text-center flex items-center justify-center text-sm font-bold md:text-base p-3 md:p-6 bg-gray"><span class="md:px-4 md:py-2 md:rounded-lg md:bg-forest-green-50">~10 minutes</span></div>
          </div>
        </div>
      </div>

      <!-- Bottom Note -->
      <div class="mt-8 text-center">
        <p class="text-charcoal/80 text-sm md:text-base">
          Trellis gives you an enterprise-level design system tailored to your brand in less than 10 minutes.
        </p>
      </div>
    </div>
  </div>
</section>
